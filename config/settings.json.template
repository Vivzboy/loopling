{
  "// note": "Merge the relevant bits into ~/.claude/settings.json (global) — do not blindly overwrite yours. Substitute {{USER}} and {{AGENT_NAME}}. Strip this note + comments (JSON has no comments).",

  "enabledPlugins": {
    "telegram@claude-plugins-official": true,
    "last30days@last30days-skill": true
  },

  "extraKnownMarketplaces": {
    "last30days-skill": {
      "source": { "source": "github", "repo": "mvanhorn/last30days-skill" }
    }
  },

  "mcpServers": {
    "telegram-{{AGENT_NAME}}": {
      "command": "bun",
      "args": [
        "run", "--cwd",
        "/Users/{{USER}}/.claude/plugins/cache/claude-plugins-official/telegram/0.0.6",
        "--shell=bun", "--silent", "start"
      ],
      "env": {
        "TELEGRAM_STATE_DIR": "/Users/{{USER}}/.{{AGENT_NAME}}/channels/telegram"
      }
    }
  }
}
